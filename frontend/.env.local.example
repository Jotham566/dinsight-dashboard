# Frontend environment template — HOST DEV ONLY.
#
# Copy to .env.local. Next.js auto-loads it for `pnpm dev` and `pnpm build`
# when run on the host:
#
#   cp .env.local.example .env.local
#   pnpm dev
#
# NOT used by the containerized stack. The Docker image bakes
# NEXT_PUBLIC_API_URL in at build time via a build-arg (default: /api/v1,
# same-origin through Caddy). See dinsight-dashboard/deploy/vm-test/ for
# the compose-based deploy.

# --- API ---------------------------------------------------------------------
# Where the FE sends API calls during host dev. The default assumes the
# backend is running on the host at :8080 (e.g. via `./dist/api-server`).
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=D'Insight Dashboard
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Feature flags (optional) -----------------------------------------------
NEXT_PUBLIC_ENABLE_PWA=false
NEXT_PUBLIC_ENABLE_ANALYTICS=false
