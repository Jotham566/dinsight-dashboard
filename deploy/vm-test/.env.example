# Copy to .env (`cp .env.example .env`) and edit the values for your VM.
# .env is gitignored; .env.example is checked in.

# --- Required ---------------------------------------------------------------

# JWT signing secret. Generate one fresh per environment:
#   openssl rand -hex 32
JWT_SECRET=replace-me-with-openssl-rand-hex-32

# Where the FE expects to be reached from a browser. The BE's CORS
# middleware allow-lists this exact value.
PUBLIC_URL=http://localhost

# --- Source-tree paths ------------------------------------------------------
# These point at the two cloned repos. Defaults assume:
#
#   <parent>/
#     ├── Dinsight_API_Enhanced/  <-- BE (DINSIGHT_API_PATH below)
#     └── dinsight-dashboard/  <-- FE (DINSIGHT_FE_PATH below)
#
# Adjust if your layout differs. Paths are relative to the compose.yml
# (i.e. relative to deploy/vm-test/).

DINSIGHT_API_PATH=../../../Dinsight_API_Enhanced
DINSIGHT_FE_PATH=../../frontend

# --- Postgres ---------------------------------------------------------------
# In production deploys this is a managed DB; for the VM smoke-test the
# postgres service in this compose file uses these creds. POSTGRES_USER /
# POSTGRES_DB feed both the postgres service and the api container, so they
# stay in sync.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dinsight

# --- Email / SMTP -----------------------------------------------------------
# Defaults deliver to the bundled mailpit sidecar (web UI at :8025). Leave
# everything below commented for the smoke-test default; uncomment + edit when
# wiring up a real SMTP relay.
#
# EMAIL_PROVIDER       smtp | log   (log writes to app logs, never sends)
# EMAIL_FROM           from-address embedded in outgoing mail
# EMAIL_FROM_NAME      display name shown in the recipient's inbox
# SMTP_HOST / PORT     relay endpoint (defaults to mailpit:1025)
# SMTP_USERNAME / SMTP_PASSWORD   relay credentials (empty for mailpit)
# SMTP_TLS             true for STARTTLS / implicit TLS, false for plaintext
# REQUIRE_EMAIL_VERIFICATION   gate /auth/login on verified email (turn on for prod)
#
# EMAIL_PROVIDER=smtp
# EMAIL_FROM=noreply@dinsight.local
# EMAIL_FROM_NAME=Dinsight
# SMTP_HOST=mailpit
# SMTP_PORT=1025
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_TLS=false
# REQUIRE_EMAIL_VERIFICATION=false
#
# --- Resend reference (production) ------------------------------------------
# Resend (https://resend.com) over standard SMTP. The sending domain must be
# verified in Resend (SPF + DKIM DNS records) before delivery works.
#
# EMAIL_PROVIDER=smtp
# EMAIL_FROM=noreply@yourdomain.com
# EMAIL_FROM_NAME=Dinsight
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465                  # 465 = implicit TLS; 587 = STARTTLS
# SMTP_USERNAME=resend           # literal string, per Resend's docs
# SMTP_PASSWORD=re_xxxxxxxxxxxx  # API key generated in the Resend UI
# SMTP_TLS=true
# REQUIRE_EMAIL_VERIFICATION=true

# --- Host UID / GID ---------------------------------------------------------
# The api image runs as the distroless 'nonroot' user (UID 65532). When it
# writes devices.json into the bind-mounted runtime/ directory, the file ends
# up owned by whatever UID is running inside the container. Override here so
# the api runs as the host user instead, keeping bind-mounted files
# readable + writable from the host shell without chown/chmod gymnastics.
#
# Default 1000 is the standard first-user UID on Ubuntu/Debian VMs and works
# unchanged for most deployments. Override if the deploy user is different;
# `id -u` and `id -g` on the host print the right values.
# HOST_UID=1000
# HOST_GID=1000

# --- Optional: host port overrides -----------------------------------------
# Useful if the VM already has something on :80 / :443.
# CADDY_HTTP_PORT=8080
# CADDY_HTTPS_PORT=8443

# --- Multi-dev isolation ----------------------------------------------------
# If two developers share the same VM, each needs isolated containers/volumes.
# Set COMPOSE_PROJECT_NAME to a unique value per developer (e.g., your initials).
# This namespaces container names and volumes so they don't collide.
# COMPOSE_PROJECT_NAME=dinsight-jw

# IMAGE_TAG lets you tag local builds distinctly (default: vm-test).
# IMAGE_TAG=vm-test-jw

# MAILPIT_PORT moves the email UI off 8025 if someone else already claimed it.
# MAILPIT_PORT=8026
